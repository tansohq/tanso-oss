# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tanso
POSTGRES_USER=tanso
# Non-functional placeholder — set a real password before deploying
POSTGRES_PASSWORD=changeme

# Backend
# Required. No default — generate a secret, e.g.: openssl rand -base64 48
JWT_SECRET=
API_PORT=8080

# MCP server (optional)
# Exposes the /mcp endpoint so AI agents can drive Tanso. Off by default.
# Set to true to enable, then connect a client. See docs/mcp-server.md.
# APP_MCP_ENABLED=false

# Frontend
VITE_TANSO_BACKEND_URL=http://localhost:8080

# Stripe (optional)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin bootstrap
ADMIN_EMAIL=admin@example.com
# Leave ADMIN_PASSWORD unset to have setup.sh generate a strong password and print it once.
# Set it explicitly only if you want to choose your own strong password.
# ADMIN_PASSWORD=
