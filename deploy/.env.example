# Copy to deploy/.env and fill in before running docker compose.

# Database
POSTGRES_DB=tanso
POSTGRES_USER=tanso
# Set a real password — "changeme" is a non-functional placeholder
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Backend
# Required. Generate one: openssl rand -base64 48
JWT_SECRET=
API_PORT=8080

# Stripe (optional — leave empty to run without Stripe)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# MCP server for AI agents (optional, off by default).
# Set both to true to expose the /mcp endpoint.
# APP_MCP_ENABLED=true
# SPRING_AI_MCP_SERVER_ENABLED=true
