{
  "name": "tanso-dashboard",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:staging": "vue-tsc --noEmit && vite build --mode staging",
    "build:sandbox": "vue-tsc --noEmit && vite build --mode sandbox",
    "build:production": "vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "check": "tsc --noEmit && eslint . && prettier --write src/"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.17.0",
    "@unovis/ts": "^1.6.2",
    "@unovis/vue": "^1.6.2",
    "@userback/widget": "^0.3.12",
    "@vee-validate/zod": "^4.12.4",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^0.562.0",
    "pinia": "^2.1.7",
    "posthog-js": "^1.360.1",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "vee-validate": "^4.12.4",
    "vue": "^3.4.0",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.2.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@tsconfig/node20": "^20.1.2",
    "@types/node": "^20.10.6",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.15.0",
    "eslint-plugin-vue": "^9.30.0",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "vite": "^7.3.0",
    "vue-tsc": "^2.1.0"
  }
}
